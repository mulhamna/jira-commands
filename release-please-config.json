{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "component": "jira-commands",
      "package-name": "jira-commands",
      "version-file": "VERSION",
      "changelog-path": "/CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "/Cargo.toml"
        },
        {
          "type": "generic",
          "path": "/crates/jira/Cargo.toml"
        },
        {
          "type": "generic",
          "path": "/crates/jira-core/Cargo.toml"
        },
        {
          "type": "generic",
          "path": "/crates/jira-mcp/Cargo.toml"
        },
        {
          "type": "generic",
          "path": "/README.md"
        },
        {
          "type": "generic",
          "path": "/INSTALL.md"
        },
        {
          "type": "generic",
          "path": "/packaging/winget/jirac.yaml"
        },
        {
          "type": "generic",
          "path": "/packaging/winget/jirac.locale.en-US.yaml"
        },
        {
          "type": "generic",
          "path": "/packaging/winget/jirac.installer.yaml"
        }
      ]
    }
  }
}
