<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>jirac</id>
    <version>0.16.5</version>
    <packageSourceUrl>https://github.com/mulhamna/jira-commands</packageSourceUrl>
    <owners>mulhamna</owners>
    <title>jirac</title>
    <authors>mulhamna</authors>
    <projectUrl>https://github.com/mulhamna/jira-commands</projectUrl>
    <licenseUrl>https://github.com/mulhamna/jira-commands/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectSourceUrl>https://github.com/mulhamna/jira-commands</projectSourceUrl>
    <docsUrl>https://github.com/mulhamna/jira-commands/blob/main/README.md</docsUrl>
    <bugTrackerUrl>https://github.com/mulhamna/jira-commands/issues</bugTrackerUrl>
    <tags>jira atlassian cli tui rust mcp</tags>
    <summary>Jira terminal client with TUI, MCP support, and native release archives.</summary>
    <description>jirac is a fast Jira CLI and TUI built in Rust. It supports interactive issue browsing, transitions, comments, worklogs, attachments, and jirac-mcp for editor and agent integrations.</description>
    <releaseNotes>https://github.com/mulhamna/jira-commands/releases/tag/v0.16.5</releaseNotes>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
    <file src="LICENSE" target="tools" />
    <file src="LICENSE-MIT" target="tools" />
    <file src="LICENSE-APACHE" target="tools" />
    <file src="README.md" target="tools" />
  </files>
</package>
